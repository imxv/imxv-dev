---
import TagBadge from './TagBadge.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  type: 'article' | 'til' | 'weekly';
  tags: string[];
  weekNumber?: number;
}

const { slug, title, description, date, type, tags, weekNumber } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const typeIcon: Record<string, string> = {
  article: '///',
  til: 'TIL',
  weekly: `W${weekNumber ?? ''}`,
};

const typeColor: Record<string, string> = {
  article: 'text-tag-blue',
  til: 'text-tag-green',
  weekly: 'text-tag-orange',
};
---

{type === 'til' ? (
  <!-- TIL: compact single line -->
  <a href={`/posts/${slug}`} class="group flex items-center gap-3 py-2 transition-colors hover:bg-bg-subtle -mx-3 px-3 rounded-md">
    <span class:list={['shrink-0 font-[family-name:var(--font-mono)] text-xs font-medium', typeColor[type]]}>
      {typeIcon[type]}
    </span>
    <span class="font-[family-name:var(--font-mono)] text-xs text-text-tertiary shrink-0">{dateStr}</span>
    <span class="text-sm text-text-primary group-hover:text-accent transition-colors truncate">{title}</span>
  </a>
) : (
  <!-- Article / Weekly: card -->
  <a href={`/posts/${slug}`} class="group block -mx-3 px-3 py-3 rounded-md transition-colors hover:bg-bg-subtle">
    <div class="flex items-center gap-2 mb-1">
      <span class:list={['font-[family-name:var(--font-mono)] text-xs font-medium', typeColor[type]]}>
        {typeIcon[type]}
      </span>
      <span class="font-[family-name:var(--font-mono)] text-xs text-text-tertiary">{dateStr}</span>
    </div>
    <h3 class="text-base font-medium text-text-primary group-hover:text-accent transition-colors mb-1">
      {title}
    </h3>
    <p class="text-sm text-text-secondary line-clamp-2 mb-2">{description}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    )}
  </a>
)}
