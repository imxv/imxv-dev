---
import { SITE } from '../data/site';
import ThemeToggle from './ThemeToggle';

const pathname = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="font-[family-name:var(--font-mono)] text-sm font-medium tracking-tight text-text-primary hover:text-accent transition-colors">
      {SITE.title}
    </a>
    <ul class="flex items-center gap-6">
      <li>
        <a
          href="/"
          class:list={[
            'text-sm transition-colors',
            pathname === '/'
              ? 'text-accent font-medium'
              : 'text-text-secondary hover:text-text-primary',
          ]}
        >
          主页
        </a>
      </li>
      {SITE.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm transition-colors',
              pathname.startsWith(item.href)
                ? 'text-accent font-medium'
                : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <ThemeToggle client:load />
      </li>
    </ul>
  </nav>
</header>
