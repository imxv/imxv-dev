---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc-nav">
    <p class="mb-2 font-[family-name:var(--font-mono)] text-xs font-medium text-text-tertiary uppercase tracking-wider">
      目录
    </p>
    <ul class="space-y-1.5 text-sm">
      {filtered.map((h) => (
        <li style={h.depth === 3 ? 'padding-left: 1rem;' : ''}>
          <a
            href={`#${h.slug}`}
            class="text-text-tertiary hover:text-accent transition-colors"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
