---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';
import TOC from '../components/TOC.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  type: 'article' | 'til' | 'weekly';
  tags: string[];
  toc: boolean;
  headings: { depth: number; slug: string; text: string }[];
  weekNumber?: number;
  ogImage?: string;
}

const { title, description, date, updated, type, tags, toc, headings, weekNumber, ogImage } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updated?.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

const wordCount = Astro.slots.has('default') ? 0 : 0; // reading time estimated below
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article>
    <!-- Back link -->
    <a href="/posts" class="mb-6 inline-flex items-center gap-1 text-sm text-text-tertiary hover:text-accent transition-colors">
      &larr; 所有文章
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="mb-3 flex items-center gap-3 font-[family-name:var(--font-mono)] text-xs text-text-tertiary">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {updated && <span>（更新于 {updatedStr}）</span>}
      </div>
      <h1 class="mb-4 text-2xl font-medium leading-snug sm:text-3xl">
        {weekNumber ? `W${weekNumber}: ` : ''}{title}
      </h1>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => <TagBadge tag={tag} interactive />)}
        </div>
      )}
    </header>

    <!-- TOC -->
    {toc && type === 'article' && <TOC headings={headings} />}

    <!-- Content -->
    <div class="prose prose-neutral">
      <slot />
    </div>
  </article>
</BaseLayout>
