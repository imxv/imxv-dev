---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage, canonicalUrl } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} />
  </head>
  <body class="bg-bg text-text-primary">
    <Header />
    <main class="mx-auto w-full max-w-4xl flex-1 px-6 py-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
